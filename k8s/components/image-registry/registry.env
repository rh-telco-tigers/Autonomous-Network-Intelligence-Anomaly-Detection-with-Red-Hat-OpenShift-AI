# Reference only (not consumed by kustomize). Main-branch GitOps uses:
#   quay.io/autonomousnetworkintelligence/<repo>:latest
QUAY_ORG=autonomousnetworkintelligence
IMAGE_TAG=latest

# Switch Tekton build push targets (k8s/overlays/gitops/tekton/kustomization.yaml):
#   openshift-tekton-build-targets   -> build into image-registry.openshift-image-registry.svc:5000 (default)
#   quay-tekton-build-targets        -> build directly to Quay
#
# The default Tekton pipeline now supports an optional final publish stage to Quay.
# Manual PipelineRuns can enable that stage without changing the build target component.

# Switch deploy pulls for ani-datascience (uses k8s/components/image-registry/quay-public-images):
#   quay-public-images               -> pull from Quay (default on main)
#   openshift-internal-images        -> pull from cluster registry (swap in datascience kustomization)
